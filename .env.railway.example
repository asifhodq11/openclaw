# ═══════════════════════════════════════════════════════════════
#  OpenClaw Railway Edition — Environment Variables Reference
#  Set ALL of these in Railway → Service → Variables tab
#  More providers = more failover resilience
# ═══════════════════════════════════════════════════════════════

# ── GATEWAY AUTH ─────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ── DATA PERSISTENCE (required — must match volume mount path) ────────
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace

# ── DEFAULT AI MODEL ─────────────────────────────────────────────────
OPENCLAW_MODEL=google/gemini-2.5-flash

# ── TELEGRAM ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=8334914208

# ── FREE AI PROVIDERS (add all you have — more = more resilience) ─────

# 1. OpenRouter → openrouter.ai → Keys (no credit card)
#    Provides: 31 free models, auto-routes among them
OPENROUTER_API_KEY=

# 2. Google AI Studio → aistudio.google.com → Get API Key (free)
#    Provides: gemini-2.5-flash (500/day), gemini-2.5-pro-exp (25/day)
GEMINI_API_KEY=

# 3. Groq → console.groq.com → API Keys (free, fastest)
#    Provides: llama-3.3-70b, llama-3.1-8b-instant (~14,400 req/day)
GROQ_API_KEY=

# 4. Mistral → console.mistral.ai → API Keys (free tier)
MISTRAL_API_KEY=

# 5. Cerebras → cloud.cerebras.ai → API Keys (free, very fast)
CEREBRAS_API_KEY=

# ── OPTIONAL ENHANCEMENTS ─────────────────────────────────────────────
# Web search skill (brave.com/search/api → free tier)
# BRAVE_API_KEY=

# Smart router verbose logging (set to 1 to enable)
# OPENCLAW_DEBUG_ROUTER=0
