# ═══════════════════════════════════════════════════
#  OpenClaw Railway Edition — Environment Variables
#  Add ALL keys you have. More keys = more resilience.
# ═══════════════════════════════════════════════════

# GATEWAY AUTH (generate at: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=your-random-token-here

# STORAGE (required for persistence)
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace

# ── FREE AI PROVIDERS ────────────────────────────────
# Get all of these — they're 100% free, no credit card

# 1. Google AI Studio → aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza...

# 2. Groq (fastest) → console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_...

# 3. OpenRouter → openrouter.ai → Keys → Create (no card needed)
OPENROUTER_API_KEY=sk-or-v1-...

# 4. Mistral → console.mistral.ai → API Keys
MISTRAL_API_KEY=...

# 5. Cerebras → cloud.cerebras.ai → API Keys
CEREBRAS_API_KEY=...

# 6. Cloudflare Workers AI → dash.cloudflare.com → Workers AI
CLOUDFLARE_AI_KEY=...
CLOUDFLARE_ACCOUNT_ID=...

# ── MESSAGING CHANNELS ──────────────────────────────
# Telegram: message @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_ALLOWED_USER_ID=

# ── RAILWAY SPECIFIC ────────────────────────────────
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
OPENCLAW_BUNDLED_VERSION=railway-edition-2026.03
RAILWAY_STATIC_URL=

# ── OPTIONAL EXTRAS ─────────────────────────────────
BRAVE_API_KEY=               # Web search (brave.com/search/api — free tier)
OPENCLAW_COST_TRACKING=true  # Track usage per session
